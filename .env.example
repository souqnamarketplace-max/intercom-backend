# Supabase Postgres connection string (use the "Connection pooling" URI from Supabase project settings)
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.lwzkvlttpqqqdelkuxpr.supabase.co:5432/postgres"

# JWT signing secret — generate a long random value, never reuse across environments
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="8h"

PORT=3000

# RS256 keypair for Virtual Key signing (private key backend-only; panels get
# only the public key, provisioned at device setup, for offline verification).
# Generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
# In production this MUST live in a proper secrets manager, not a plain .env file.
VIRTUAL_KEY_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
VIRTUAL_KEY_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# First-run bootstrap account (see prisma/seed.ts) — change the password immediately after first login
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="change-me-immediately"
